{
    "name": "Clinic-in-a-Phone",
    "short_name": "ClinicPhone",
    "description": "Your personal health assistant for symptom checking, fitness tracking, and finding nearby clinics",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#3B82F6",
    "orientation": "portrait-primary",
    "scope": "/",
    "lang": "en",
    "categories": ["health", "fitness", "medical", "lifestyle"],
    "screenshots": [
        {
            "src": "/static/images/screenshot1.png",
            "sizes": "1280x720",
            "type": "image/png",
            "form_factor": "wide",
            "label": "Home screen with daily health features"
        },
        {
            "src": "/static/images/screenshot2.png",
            "sizes": "750x1334",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Symptom checker interface"
        }
    ],
    "icons": [
        {
            "src": "/static/images/logo.svg",
            "sizes": "32x32",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        },
        {
            "src": "/static/images/logo-large.svg",
            "sizes": "192x192",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        },
        {
            "src": "/static/images/logo-large.svg",
            "sizes": "512x512",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        }
    ],
    "shortcuts": [
        {
            "name": "Symptom Checker",
            "short_name": "Symptoms",
            "description": "Check your symptoms and get health advice",
            "url": "/symptom",
            "icons": [
                {
                    "src": "/static/images/symptom-icon.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Fitness",
            "short_name": "Fitness",
            "description": "Access exercise routines and fitness tips",
            "url": "/fitness",
            "icons": [
                {
                    "src": "/static/images/fitness-icon.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Find Clinics",
            "short_name": "Clinics",
            "description": "Locate nearby healthcare facilities",
            "url": "/clinics",
            "icons": [
                {
                    "src": "/static/images/clinic-icon.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "related_applications": [],
    "prefer_related_applications": false,
    "edge_side_panel": {
        "preferred_width": 400
    },
    "launch_handler": {
        "client_mode": "focus-existing"
    },
    "protocol_handlers": [
        {
            "protocol": "web+clinic",
            "url": "/symptom?symptom=%s"
        }
    ],
    "file_handlers": [
        {
            "action": "/fitness",
            "accept": {
                "application/json": [".json"]
            }
        }
    ],
    "share_target": {
        "action": "/",
        "method": "GET",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    }
}
